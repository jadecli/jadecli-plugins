{
  "name": "Docker Desktop",
  "bundle_id": "com.docker.docker",
  "category": "runtime",
  "surface": "menubar",
  "price": "free-tier",
  "install_method": "brew",
  "install_command": "brew install --cask docker",
  "verify_command": "docker info --format '{{.ServerVersion}}'",
  "cli_tools": ["docker", "docker compose"],
  "mcp_server": {
    "command": "docker",
    "args": ["mcp", "server"]
  },
  "recommended_settings": {
    "memory_limit_gb": 8,
    "cpu_limit": 4,
    "disk_limit_gb": 64
  },
  "login_item": true,
  "claude_code_surfaces": ["cli", "mcp", "hooks"],
  "description": "Container runtime for dev databases and services with MCP server integration"
}
